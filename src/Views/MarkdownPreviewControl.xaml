<UserControl x:Class="emMDee.Views.MarkdownPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- WebView2 not available banner -->
        <Border x:Name="WebViewMissingBanner"
                Grid.Row="0"
                Background="#FFF3CD"
                BorderBrush="#FFEEBA"
                BorderThickness="0,0,0,1"
                Padding="12,8"
                Visibility="Collapsed">
            <TextBlock Text="WebView2 Runtime is not installed. Markdown preview requires the WebView2 Runtime.&#x0a;Download it from: https://go.microsoft.com/fwlink/p/?LinkId=2124703"
                       TextWrapping="Wrap"
                       Foreground="#856404"/>
        </Border>

        <!-- WebView2 host -->
        <wv2:WebView2 x:Name="WebView"
                      Grid.Row="1"
                      Visibility="Collapsed"/>
    </Grid>
</UserControl>
